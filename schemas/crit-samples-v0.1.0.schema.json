{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vulnetix.com/schemas/crit-samples-v0.1.0.schema.json",
  "title": "CRIT Test Samples",
  "description": "Generated CRIT sample values produced by interpolating dictionary templates with wordlist values.",
  "type": "object",
  "required": ["generated_at", "wordlists", "samples"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Self-reference for IDE-level validation."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation."
    },
    "wordlists": {
      "type": "object",
      "description": "Map of provider -> slot-name -> values used for generation. Stored once to avoid repetition.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sample" },
      "description": "Array of resolved CRIT sample values."
    }
  },
  "$defs": {
    "sample": {
      "type": "object",
      "required": ["provider", "service", "resource_type", "template", "template_format", "region_behavior", "slot_values", "resolved"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "enum": ["aws", "azure", "gcp", "cloudflare", "oracle", "salesforce", "sap", "servicenow", "ibm", "vmware"],
          "description": "Cloud provider key."
        },
        "service": {
          "type": "string",
          "description": "Service key from dictionary entry."
        },
        "resource_type": {
          "type": "string",
          "description": "Resource type from dictionary entry."
        },
        "template": {
          "type": "string",
          "description": "Original CRIT template string with slot syntax."
        },
        "template_format": {
          "enum": ["aws_arn", "azure_resource_id", "gcp_resource_name", "cloudflare_locator", "oracle_ocid", "salesforce_url", "sap_btp_url", "sap_odata_url", "sap_sf_url", "servicenow_table_url", "ibm_url", "vmware_url"],
          "description": "Format of the resolved template."
        },
        "region_behavior": {
          "enum": ["regional", "global-only"],
          "description": "Whether the resource is regional or globally scoped."
        },
        "slot_values": {
          "type": "object",
          "description": "Map of slot-name -> concrete value used for this sample.",
          "additionalProperties": { "type": "string" }
        },
        "resolved": {
          "type": "string",
          "minLength": 1,
          "description": "Fully resolved identifier after slot substitution."
        }
      }
    }
  }
}
