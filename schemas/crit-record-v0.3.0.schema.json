{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vulnetix.com/schemas/crit-record-v0.3.0.schema.json",
  "title": "CRIT Record",
  "description": "Schema for a hand-authored CRIT record (v0.3.0). Each record describes the scope, remediation, and detection characteristics of a single vulnerability as it applies to a single cloud resource type.",
  "type": "object",
  "required": [
    "vectorString",
    "vuln_id",
    "provider",
    "service",
    "resource_type",
    "resource_lifecycle",
    "shared_responsibility",
    "vex_status",
    "template",
    "template_format",
    "temporal",
    "fix_propagation",
    "existing_deployments_remain_vulnerable",
    "remediation_actions"
  ],
  "additionalProperties": false,
  "properties": {
    "vectorString": {
      "type": "string",
      "pattern": "^CRITv\\d+\\.\\d+\\.\\d+/",
      "description": "Canonical CRIT vector string computed from record fields."
    },
    "vuln_id": {
      "type": "string",
      "minLength": 1,
      "description": "Vulnerability identifier (e.g., CVE-2024-6387)."
    },
    "provider": {
      "enum": [
        "aws", "azure", "gcp", "cloudflare", "oracle", "salesforce", "sap", "servicenow",
        "ibm", "vmware",
        "adobe", "akamai", "alibaba", "atlassian", "digitalocean", "elastic", "fastly",
        "gitlab", "hashicorp", "hetzner", "linode", "mongodb", "ovh", "snowflake", "tailscale",
        "tencent", "twilio", "vercel", "vultr", "zoom"
      ],
      "description": "Cloud provider key."
    },
    "service": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Provider service key."
    },
    "resource_type": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_/-]*$",
      "description": "Resource type within the service."
    },
    "resource_lifecycle": {
      "enum": ["ephemeral", "stateful_managed", "stateful_customer", "config_only", "global_control_plane"],
      "description": "Operational behaviour of the resource type."
    },
    "shared_responsibility": {
      "enum": ["provider_only", "customer_action_required", "customer_only", "shared"],
      "description": "Remediation responsibility model."
    },
    "vex_status": {
      "enum": ["affected", "fixed", "not_affected", "under_investigation"],
      "description": "VEX status of the record."
    },
    "template": {
      "type": "string",
      "minLength": 1,
      "description": "Parameterised identifier string with variable slots."
    },
    "template_format": {
      "enum": [
        "aws_arn", "azure_resource_id", "gcp_resource_name", "cloudflare_locator",
        "oracle_ocid", "salesforce_url", "sap_btp_url", "sap_odata_url", "sap_sf_url",
        "servicenow_table_url", "ibm_url", "vmware_url",
        "akamai_url", "alibaba_arn", "atlassian_locator", "digitalocean_url",
        "elastic_locator", "gitlab_locator", "hetzner_locator", "linode_locator",
        "mongodb_locator", "ovh_locator", "snowflake_locator", "tencent_arn",
        "twilio_resource_id", "vercel_locator", "vultr_locator", "zoom_locator",
        "uri"
      ],
      "description": "Provider-native identifier schema."
    },
    "temporal": { "$ref": "#/$defs/temporal" },
    "fix_propagation": {
      "enum": ["automatic", "config_change", "opt_in", "version_update", "redeploy", "rebuild_and_redeploy", "destroy_recreate", "rolling_replace", "no_fix_available"],
      "description": "Mechanism by which the fix reaches existing deployed resources."
    },
    "existing_deployments_remain_vulnerable": {
      "type": "boolean",
      "description": "Whether resources deployed before provider_fix_date remain in the exposure window."
    },
    "provider_fix_version": { "$ref": "#/$defs/provider_fix_version" },
    "remediation_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/remediation_action" },
      "description": "Ordered array of remediation steps."
    },
    "detections": {
      "type": "array",
      "items": { "$ref": "#/$defs/detection" },
      "description": "Detection queries and alerting rules."
    },
    "provider_advisory": { "$ref": "#/$defs/provider_advisory" }
  },
  "$defs": {
    "temporal": {
      "type": "object",
      "required": ["vuln_published_date", "service_available_date"],
      "additionalProperties": false,
      "properties": {
        "service_available_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Date the provider service became generally available."
        },
        "vulnerability_introduced_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "When the vulnerability was first present."
        },
        "vulnerability_introduced_date_estimated": {
          "type": "boolean",
          "description": "Whether vulnerability_introduced_date is an estimate."
        },
        "vuln_published_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Date the vulnerability was publicly disclosed."
        },
        "provider_acknowledged_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "When the provider first confirmed the vulnerability."
        },
        "provider_fix_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Date the provider made a fix generally available."
        },
        "customer_deadline_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Normative remediation deadline."
        },
        "customer_deadline_source": {
          "type": "string",
          "description": "Source of the customer deadline (e.g., cisa_kev)."
        }
      }
    },
    "provider_fix_version": {
      "type": "object",
      "required": ["version_type", "comparison"],
      "additionalProperties": false,
      "properties": {
        "version_type": {
          "type": "string",
          "description": "Type of versioning system for this service."
        },
        "comparison": {
          "enum": ["gte", "exact", "date_gte", "channel_and_gte"],
          "description": "How to evaluate whether a resource meets the fix threshold."
        },
        "version": {
          "type": "string",
          "description": "Fix version string."
        },
        "channel": {
          "type": "string",
          "description": "Release channel qualifier."
        },
        "build_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Build date of the fixed artifact."
        },
        "auto_upgrade": {
          "type": "boolean",
          "description": "Whether the provider automatically applies the version update."
        },
        "note": {
          "type": "string",
          "description": "Human-readable guidance on applying the fix."
        },
        "image_digest": {
          "type": "string",
          "description": "Container image digest for exact matching."
        },
        "image_tag": {
          "type": "string",
          "description": "Container image tag."
        },
        "engine": {
          "type": "string",
          "description": "Database or runtime engine identifier (e.g., mysql, postgres)."
        }
      }
    },
    "remediation_action": {
      "type": "object",
      "required": ["sequence", "type", "title", "description", "auto_remediable", "requires_downtime", "compensating_control"],
      "additionalProperties": true,
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1,
          "description": "1-based ordering index."
        },
        "type": {
          "type": "string",
          "description": "Type of remediation action."
        },
        "title": {
          "type": "string",
          "description": "Short human-readable title."
        },
        "description": {
          "type": "string",
          "description": "Step-by-step instructions."
        },
        "auto_remediable": {
          "type": "boolean",
          "description": "Whether the action can be automated."
        },
        "requires_downtime": {
          "type": "boolean",
          "description": "Whether the action requires service downtime."
        },
        "estimated_downtime_range_seconds": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "integer", "minimum": 0 },
            "max": { "type": "integer", "minimum": 0 }
          },
          "description": "Estimated downtime range when requires_downtime is true."
        },
        "compensating_control": {
          "type": "boolean",
          "description": "Whether this is a mitigation rather than a full fix."
        }
      }
    },
    "detection": {
      "type": "object",
      "required": ["provider", "service", "query_language", "query", "detection_phase", "description"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "description": "Cloud provider for this detection."
        },
        "service": {
          "type": "string",
          "description": "Detection service."
        },
        "query_language": {
          "type": "string",
          "description": "Query language of the query string."
        },
        "query": {
          "type": "string",
          "description": "Detection query string. Empty when pending_reason is set."
        },
        "detection_phase": {
          "enum": ["pre_fix", "exploitation", "post_fix", "misconfiguration"],
          "description": "Lifecycle phase of the detection."
        },
        "description": {
          "type": "string",
          "description": "Explanation of what the query detects."
        },
        "pending_reason": {
          "enum": ["query_in_development", "awaiting_provider_telemetry", "no_detection_surface", "access_constraint", "pending_review"],
          "description": "Why a detection entry is a placeholder without a functional query."
        }
      }
    },
    "provider_advisory": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "advisory_id": {
          "type": "string",
          "description": "Provider's own advisory identifier."
        },
        "advisory_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to the provider's security advisory."
        }
      }
    }
  }
}
