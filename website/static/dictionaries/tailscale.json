    {
      "service": "ssh",
      "resource_type": "session",
      "template": "https://login.tailscale.com/admin/ssh/{session}",
      "template_format": "uri",
      "region_behavior": "global-only"
    },
    {
      "service": "acl",
      "resource_type": "policy",
      "template": "https://login.tailscale.com/admin/acls/{policy}",
      "template_format": "uri",
      "region_behavior": "global-only"
    }
