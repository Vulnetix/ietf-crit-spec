      "resource_type": "cluster",
      "template": "https://api.linode.com/v4/lke/clusters/{cluster-id}",
      "template_format": "linode_locator",
      "region_behavior": "regional"
    },
    {
      "service": "managed_database",
      "resource_type": "db_instance",
      "template": "https://api.linode.com/v4/databases/{engine}/instances/{database-id}",
      "template_format": "linode_locator",
      "region_behavior": "regional"
